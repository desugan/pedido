generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id_cliente    Int         @id @default(autoincrement())
  nome          String
  status        String?     @default("ATIVO")
  contato       String?
  createdAt     DateTime    @default(now()) @map("data")
  updatedAt     DateTime    @updatedAt
  financeiro    Financeiro?
  usuarios      Usuario[]
  pedidos       Pedido[]
  pagamentos    Pagamento[]

  @@map("cliente")
}

model Financeiro {
  id_financeiro   Int       @id @default(autoincrement())
  id_cliente      Int       @unique
  cliente         Cliente   @relation(fields: [id_cliente], references: [id_cliente])
  limite_credito  Float     @default(0)
  saldo_utilizado Float     @default(0)
  ultimo_limite   Float     @default(0)
  data_criacao    DateTime  @default(now())
  usuario_alteracao String? @default("SISTEMA")

  @@map("financeiro")
}

model Perfil {
  id_perfil  Int       @id @default(autoincrement())
  perfil    String
  usuarios  Usuario[]

  @@map("perfil")
}

model Usuario {
  id_usuario  Int      @id @default(autoincrement())
  id_cliente  Int?
  cliente     Cliente? @relation(fields: [id_cliente], references: [id_cliente])
  id_perfil   Int
  perfil      Perfil   @relation(fields: [id_perfil], references: [id_perfil])
  usuario     String   @unique
  senha       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("usuario")
}

model Produto {
  id_produto  Int      @id @default(autoincrement())
  nome        String
  valor       Float
  oldvalor    Float?
  marca       String?
  saldo       Float    @default(0)
  createdAt   DateTime @default(now()) @map("data")
  updatedAt   DateTime @updatedAt
  pedidoItems PedidoItem[]
  lancamentoItems LancamentoItem[]

  @@map("produto")
}

model Pedido {
  id_pedido          Int              @id @default(autoincrement())
  id_cliente         Int
  cliente            Cliente          @relation(fields: [id_cliente], references: [id_cliente])
  total              Float
  status             String           @default("pendente")
  createdAt          DateTime         @default(now()) @map("data")
  updatedAt          DateTime         @updatedAt
  itens              PedidoItem[]
  pedidoPagamentos   PedidoPagamento[]

  @@map("pedido")
}

model PedidoItem {
  id_item_pedido  Int     @id @default(autoincrement())
  id_pedido       Int
  pedido          Pedido  @relation(fields: [id_pedido], references: [id_pedido])
  id_produto      Int
  produto         Produto @relation(fields: [id_produto], references: [id_produto])
  qtd             Float
  vlr_item        Float
  vlr_total       Float
  vlr_custo       Float   @default(0)

  @@map("pedido_item")
}

model Fornecedor {
  id_fornecedor  Int              @id @default(autoincrement())
  razao          String
  cnpj           String
  status        String?          @default("ATIVO")
  data           DateTime         @default(now())
  lancamentos   Lancamento[]

  @@map("fornecedor")
}

model Lancamento {
  id_lancamento   Int               @id @default(autoincrement())
  id_fornecedor   Int
  fornecedor      Fornecedor        @relation(fields: [id_fornecedor], references: [id_fornecedor])
  total           Float
  status          String            @default("PENDENTE")
  data            DateTime          @default(now())
  documento       String?
  chave           String?
  id_usuario      Int?
  itens           LancamentoItem[]

  @@map("lancamento")
}

model LancamentoItem {
  id_lancamento_item  Int         @id @default(autoincrement())
  id_lancamento       Int
  lancamento          Lancamento @relation(fields: [id_lancamento], references: [id_lancamento])
  id_produto          Int
  produto             Produto     @relation(fields: [id_produto], references: [id_produto])
  qtd                 Float
  vlr_item            Float
  vlr_total           Float

  @@map("lancamento_item")
}

model Pagamento {
  id_pagamento    Int              @id @default(autoincrement())
  id_cliente      Int
  cliente         Cliente          @relation(fields: [id_cliente], references: [id_cliente])
  valor           Float
  qrcode          String?          @map("qr_code")
  chavepix        String?          @map("chave_pix")
  status          String           @default("pendente")
  data_criacao    DateTime         @default(now()) @map("data_criacao")
  data_pagamento  DateTime?        @map("data_pagamento")
  updatedAt       DateTime         @updatedAt
  pedidoPagamentos PedidoPagamento[]

  @@map("pagamento")
}

model PedidoPagamento {
  id_pagamento_pedido Int      @id @default(autoincrement())
  id_pedido           Int
  id_pagamento        Int
  pedido              Pedido  @relation(fields: [id_pedido], references: [id_pedido])
  pagamento           Pagamento @relation(fields: [id_pagamento], references: [id_pagamento])

  @@map("pagamentopedido")
}

model AppConfig {
  config_key   String @id @map("config_key")
  config_value String? @map("config_value")

  @@map("app_config")
}