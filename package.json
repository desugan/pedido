{
  "name": "pedido-workspace",
  "version": "1.5.0",
  "description": "Buteco do TI workspace",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n BACKEND,FRONTEND -c cyan,green \"node backend_express/server.js\" \"npm --prefix frontend run dev\"",
    "dev:backend": "node backend_express/server.js",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build"
  },
  "keywords": [
    "pedidos",
    "api",
    "flask"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "typescript": "^5.3.3"
  }
}