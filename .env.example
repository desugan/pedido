# ============================================
# BUTECO DO TI - CONFIGURACAO
# ============================================

# --- BANCO DE DADOS ---
# MySQL connection
DATABASE_URL=mysql://usuario:senha@localhost:3306/pedido

# --- JWT (gere uma chave segura) ---
JWT_SECRET=sua-chave-jwt-aqui-minimo-256-bits
JWT_ISSUER=pedido-api
JWT_AUDIENCE=pedido-frontend
JWT_TTL_MINUTES=15

# --- CORS ---
# Origens permitidas (separadas por virgula)
CORS_ORIGIN=http://localhost:5173

# --- FLASK ---
FLASK_ENV=development
PORT=5000
API_URL=http://localhost:5000

# --- FRONTEND ---
VITE_API_URL=http://localhost:5000

# --- DATABASE POOL ---
DB_POOL_SIZE=5
